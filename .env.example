# Carbochem Helpdesk - Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# MongoDB (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/helpdesk

# JWT Authentication
JWT_SECRET=carbochem_helpdesk_jwt_secret_2025

# Admin registration secret key (used on login page Admin Sign Up)
ADMIN_SECRET_KEY=CARBOCHEM2024

# Optional: Enable auto-assignment of tickets to staff on creation
# AUTO_ASSIGN=false

# Optional: Email OTP (leave blank to log OTPs to console)
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_gmail_app_password
